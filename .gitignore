# Composer
/vendor/

# Node (asset pipeline — not part of the plugin release)
/node_modules/
/.playwright-browsers/

# Translation PHP cache (generated by Poedit; stale cache breaks translations in WP 6.7+)
languages/*.l10n.php
composer_2.phar
composer.phar

