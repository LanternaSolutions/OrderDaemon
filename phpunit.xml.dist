<?xml version="1.0"?>
<!--
PHPUnit Configuration File

This file configures PHPUnit for testing the Order Daemon plugin. It defines:
- Bootstrap file location
- Test behavior settings
- Test suites organization
- Environment variables and constants

This is a .dist (distribution) file that should be committed to version control.
Developers can copy it to phpunit.xml and make local modifications that won't be committed.
-->
<phpunit
	bootstrap="tests/bootstrap.php"
	backupGlobals="false"
	colors="true"
	convertErrorsToExceptions="true"
	convertWarningsToExceptions="true"
	convertNoticesToExceptions="true"
	convertDeprecationsToExceptions="true"
	>
	<!-- 
	Test Suites Configuration

	We organize tests into two main categories:
	1. Unit tests: Fast tests that don't require WordPress
	2. Integration tests: Tests that interact with WordPress

	Each suite is run separately with different configuration.
	-->
	<testsuites>
		<!-- Unit Test Suite: For testing isolated components without WordPress -->
		<testsuite name="Unit">
			<directory>./tests/Unit/</directory>
		</testsuite>

		<!-- Integration Test Suite: For testing WordPress integration -->
		<testsuite name="Integration">
			<directory>./tests/Integration/</directory>
		</testsuite>
	</testsuites>

	<!-- 
	PHP Settings

	These settings define environment variables and constants that are
	available during test execution. They're particularly important for
	locating WordPress test libraries and polyfills.
	-->
	<php>
		<!-- Path to WordPress test library within Docker container -->
		<env name="WP_TESTS_DIR" value="/var/www/html/wp-content/plugins/order-daemon/tests/wordpress-test-lib"/>

		<!-- Path to PHPUnit polyfills for compatibility with different PHPUnit versions -->
		<const name="WP_TESTS_PHPUNIT_POLYFILLS_PATH" value="/var/www/html/wp-content/plugins/order-daemon/vendor/yoast/phpunit-polyfills/"/>
	</php>
</phpunit>
